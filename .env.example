# Telegram bot token.
# Где найти: Telegram -> @BotFather -> /newbot или /token.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# OpenAI API key for bot responses and vector embeddings.
# Где найти: https://platform.openai.com/api-keys
OPENAI_API_KEY=changeme-openai-key

# OpenAI model used by support-bot.
OPENAI_MODEL=gpt-4o

# System prompt file inside support-bot container.
OPENAI_SYSTEM_PROMPT_FILE=system_prompt.txt

# Optional temperature for models that support it.
# OPENAI_TEMPERATURE=0.7

# Optional reasoning effort for reasoning models.
# OPENAI_REASONING_EFFORT=low

# Optional HTTP/HTTPS/SOCKS5 proxy for every OpenAI request from bot and vector-base.
# If SSH SOCKS5 proxy runs on the Docker host, use socks5://host.docker.internal:8080.
# Leave empty to use the default network path.
# OPENAI_PROXY_URL=socks5://host.docker.internal:8080

# Optional Compose profile for Linux hosts where the proxy listens only on 127.0.0.1.
# It starts host-proxy-forwarder: host 127.0.0.1:${HOST_PROXY_SOURCE_PORT} -> host 0.0.0.0:${HOST_PROXY_FORWARD_PORT}.
# Then containers should use socks5://host.docker.internal:${HOST_PROXY_FORWARD_PORT}.
# COMPOSE_PROFILES=host-proxy-forwarder
# HOST_PROXY_SOURCE_PORT=8080
# HOST_PROXY_FORWARD_PORT=18080

# Alternative for Linux servers with Docker-to-host bridge traffic blocked.
# Run host-network services from docker-compose.yml:
# docker compose --profile host-network up -d --build chroma-host vector-base-host bot-host
# Use API_PORT=8081, VECTOR_BASE_URL=http://127.0.0.1:8081,
# CHROMA_HOST=127.0.0.1, and socks5://127.0.0.1:8080 for OpenAI/Telegram.

# Optional HTTP/HTTPS/SOCKS5 proxy for Telegram API requests.
# Use this when api.telegram.org is unavailable from the server directly.
# TELEGRAM_PROXY_URL=socks5://host.docker.internal:8080

# Operator Telegram chat ID for escalation notifications.
# Где найти: Telegram -> @userinfobot.
OPERATOR_CHAT_ID=123456789

# Operator name shown to users.
OPERATOR_NAME=Оператор

# SQLite database path inside bot container.
DATABASE_PATH=./data/chatbot.db

# Message debounce settings.
DEBOUNCE_DELAY=4
MAX_BUFFER_AGE=3600

# Image limits for support-bot.
MAX_IMAGES=10
MIN_PHOTO_WIDTH=800

# OpenAI response timeout for support-bot before operator transfer.
OPENAI_RUN_TIMEOUT=300

# Internal vector search API URL in this Docker Compose stack.
VECTOR_BASE_URL=http://vector-base:8080

# Host port for vector-base health/API. Use 8081 if 8080 is occupied by OpenAI proxy.
VECTOR_BASE_PUBLISHED_PORT=8081

# Embedding model used by vector-base.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Search quality settings.
SEARCH_TOP_K=3
SEARCH_CANDIDATE_MULTIPLIER=4
SEARCH_MIN_SCORE=0.05
SEARCH_KEYWORD_LIMIT=2000

# Google service account file mounted into vector-base container.
# Где найти: Google Cloud Console -> IAM -> Service Accounts -> Keys.
# Сохранить файл локально как vector-base/secrets/google_service_account.json.
GOOGLE_SERVICE_ACCOUNT_FILE=/secrets/google_service_account.json

# Google Docs IDs separated by commas.
# Где найти: docs.google.com/document/d/<DOCUMENT_ID>/edit
GOOGLE_DOC_IDS=doc-id-1,doc-id-2

# Google API retry and pacing settings.
GOOGLE_REQUEST_INTERVAL_SECONDS=0.25
GOOGLE_MAX_RETRIES=5
GOOGLE_RETRY_INITIAL_DELAY=1.0

# ChromaDB connection from vector-base container.
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=knowledge

# Document chunking settings.
EMBEDDING_CHUNK_SIZE=350
EMBEDDING_CHUNK_OVERLAP=60

# Scheduled Google Docs sync interval in minutes.
SYNC_INTERVAL_MINUTES=15

# HTTP API port inside vector-base container.
API_PORT=8080

# Logging level.
LOG_LEVEL=INFO
